{
  "name": "modelviewer-ar-server",
  "version": "1.0.0",
  "description": "HTTPS server for <model-viewer> augmented reality examples, with animated AR Quick Look support on iOS.",
  "type": "module",
  "scripts": {
    "build": "esbuild src/client/main.ts --bundle --format=esm --target=es2020 --outfile=public/main.js",
    "watch": "esbuild src/client/main.ts --bundle --format=esm --target=es2020 --outfile=public/main.js --watch",
    "typecheck": "tsc --noEmit",
    "usdz": "node tools/build-usdz.ts",
    "start": "npm run build && node server.ts",
    "dev": "npm run build && node server.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "selfsigned": "^2.4.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2"
  }
}
